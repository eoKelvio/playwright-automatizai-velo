# This file explains how to set up environment variables for your tests.
# Choose the approach that best fits your project requirements.

# OPTION 1: SINGLE ENVIRONMENT
#
# Use when your client has ONLY ONE environment to test
#
# STEPS:
#   1. Create file: .env
#   2. Add variables WITHOUT suffix
#   3. In code, use: getEnv('VARIABLE_NAME')
#
# Example file: .env

BASE_URL=https://web.example.com
API_URL=https://api.example.com
USER_EMAIL=test@example.com
USER_PASSWORD=your-password-here


# OPTION 2: MULTIPLE ENVIRONMENTS
#
# Use when your client has MULTIPLE environments (prod, staging, dev, qa, etc.)
#
# STEPS:
#   1. Create separate files for each environment:
#      - .env.prod
#      - .env.staging
#      - .env.dev
#      - .env.qa
#
#   2. Add variables WITHOUT suffix in each file
#
#   3. In shared/selectEnv.js, change ENVIRONMENT to switch:
#      const ENVIRONMENT = 'PROD'  // or 'STAGING', 'DEV', 'QA'
#
#   4. In code, use: getEnvFrom('VARIABLE_NAME')
#
# Example file: .env.prod

BASE_URL=https://app.production.com
API_URL=https://api.production.com
USER_EMAIL=test@production.com
USER_PASSWORD=prod-password

# Example file: .env.staging
BASE_URL=https://app.staging.com
API_URL=https://api.staging.com
USER_EMAIL=test@staging.com
USER_PASSWORD=staging-password